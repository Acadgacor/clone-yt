rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Mengizinkan siapa pun (termasuk tamu) untuk membaca pengaturan teater
    // Namun hanya pengguna yang terautentikasi yang dapat mengubahnya (admin)
    match /settings/theater {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Aturan default: melarang semua akses lain untuk keamanan
    match /{document=**} {
      allow read, write: if false;
    }
  }
}