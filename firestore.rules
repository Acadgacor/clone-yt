rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Pengaturan global teater (untuk halaman admin)
    match /settings/theater {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Pengaturan video per pengguna
    // Hanya pemilik dokumen yang bisa membaca dan menulis data mereka sendiri
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}