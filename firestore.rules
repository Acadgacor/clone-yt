/**
 * @file Firebase Security Rules for CineView Application
 *
 * @description This ruleset enforces a strict user-ownership model for user-specific data
 * and allows public read access to video metadata. It leverages path-based authorization
 * to ensure that users can only access their own data.
 *
 * @dataStructure
 * - /users/{userId}: Stores user profile information. Only the authenticated user can access their own profile.
 * - /videos/{videoId}: Stores video metadata. This is a public collection with owner-only writes.
 * - /recommendations/{recommendationId}: Stores AI-generated video recommendations.
 * - /users/{userId}/interactions/{interactionId}: Stores user-specific video interaction data. Only the authenticated user can access their own interactions.
 * - /users/{userId}/video/current: Stores the current video the user is watching. Only accessible to the user.
 *
 * @keySecurityDecisions
 * - Users can only create, read, update, and delete their own profile and interaction data.
 * - Video metadata is publicly readable, but writes are not allowed in this prototype.
 * - Listing of user data is restricted to the owning user.
 *
 * @denormalizationForAuthorization
 * - User-specific data is nested under the `/users/{userId}` path, eliminating the need for
 *   `get()` calls to verify ownership. The `userId` in the path is directly compared to
 *   `request.auth.uid`.
 *
 * @structuralSegregation
 * - User-specific data and public video metadata are stored in separate collections to avoid
 *   mixing different access requirements.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to manage their own profile.
     * @path /users/{userId}
     * @allow (create) User with ID 'Q9oKyFInlXhAiNhxFiByEysDsY32' can create their profile if request.auth.uid matches the userId.
     * @allow (get) User with ID 'Q9oKyFInlXhAiNhxFiByEysDsY32' can read their profile.
     * @allow (update) User with ID 'Q9oKyFInlXhAiNhxFiByEysDsY32' can update their profile.
     * @allow (delete) User with ID 'Q9oKyFInlXhAiNhxFiByEysDsY32' can delete their profile.
     * @deny (create) User with ID 'otherUserId' cannot create a profile with userId 'Q9oKyFInlXhAiNhxFiByEysDsY32'.
     * @deny (get) User with ID 'otherUserId' cannot read the profile of user 'Q9oKyFInlXhAiNhxFiByEysDsY32'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows public read access to video metadata.
     * @path /videos/{videoId}
     * @allow (get) Any user can read video metadata.
     * @allow (list) Any user can list video metadata.
     * @deny (create) No user can create video metadata (writes disabled in this prototype).
     * @deny (update) No user can update video metadata (writes disabled in this prototype).
     * @deny (delete) No user can delete video metadata (writes disabled in this prototype).
     */
    match /videos/{videoId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows public read access to recommendations.
     * @path /recommendations/{recommendationId}
     * @allow (get) Any user can read a recommendation.
     * @allow (list) Any user can list recommendations.
     * @deny (create) No user can create recommendation (writes disabled in this prototype).
     * @deny (update) No user can update recommendation (writes disabled in this prototype).
     * @deny (delete) No user can delete recommendation (writes disabled in this prototype).
     */
    match /recommendations/{recommendationId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows users to manage their own video interaction data.
     * @path /users/{userId}/interactions/{interactionId}
     * @allow (create) User with ID 'Q9oKyFInlXhAiNhxFiByEysDsY32' can create an interaction if request.auth.uid matches the userId.
     * @allow (get) User with ID 'Q9oKyFInlXhAiNhxFiByEysDsY32' can read their interaction.
     * @allow (update) User with ID 'Q9oKyFInlXhAiNhxFiByEysDsY32' can update their interaction.
     * @allow (delete) User with ID 'Q9oKyFInlXhAiNhxFiByEysDsY32' can delete their interaction.
     * @deny (create) User with ID 'otherUserId' cannot create an interaction for user 'Q9oKyFInlXhAiNhxFiByEysDsY32'.
     * @deny (get) User with ID 'otherUserId' cannot read the interactions of user 'Q9oKyFInlXhAiNhxFiByEysDsY32'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/interactions/{interactionId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

        /**
     * @description Allows users to manage their own current video.
     * @path /users/{userId}/video/current
     * @allow (get) User with ID 'Q9oKyFInlXhAiNhxFiByEysDsY32' can get their current video.
     * @allow (create) User with ID 'Q9oKyFInlXhAiNhxFiByEysDsY32' can create their current video if request.auth.uid matches the userId.
     * @allow (update) User with ID 'Q9oKyFInlXhAiNhxFiByEysDsY32' can update their current video.
     * @allow (delete) User with ID 'Q9oKyFInlXhAiNhxFiByEysDsY32' can delete their current video.
     * @deny (create) User with ID 'otherUserId' cannot create a current video for user 'Q9oKyFInlXhAiNhxFiByEysDsY32'.
     * @deny (get) User with ID 'otherUserId' cannot get the current video of user 'Q9oKyFInlXhAiNhxFiByEysDsY32'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/video/current {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
  }
}