/**
 * @fileoverview Firestore Security Rules for CineView application.
 *
 * Core Philosophy:
 * This ruleset allows public read access to all videos, while restricting write access.
 *
 * Data Structure:
 * All video data is stored in a flat `/videos/{videoId}` collection.
 *
 * Key Security Decisions:
 * - Public read access is granted to the `/videos` collection.
 * - Write access (create, update, delete) to the `/videos` collection is denied.
 * - No user-specific data or collaborative features are implemented, so there are no ownership or role-based restrictions.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants public read access to videos, but denies write access.
     * @path /videos/{videoId}
     * @allow (get, list) Any user can read any video.
     * @deny (create, update, delete) No user can create, update, or delete videos.
     * @principle Allows public read access while restricting write operations.
     */
    match /videos/{videoId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}