
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Memperbolehkan akses publik (baca/tulis) untuk pengaturan theater
    match /settings/theater {
      allow read, write: if true;
    }
    
    // Aturan default untuk koleksi lainnya (opsional, tetap aman)
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
