{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "name": {
          "type": "string",
          "description": "The user's display name."
        }
      },
      "required": ["uid", "email"]
    },
    "Video": {
      "title": "Video",
      "description": "Represents a video with its URL and title.",
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "The URL of the video."
        },
        "title": {
          "type": "string",
          "description": "The title of the video."
        }
      },
      "required": ["url", "title"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores all user-specific data. Only the authenticated user can read or write their own documents and subcollections."
    },
    "/users/{userId}/video/{videoId}": {
      "schema": {
        "$ref": "#/entities/Video"
      },
      "description": "Stores user-specific videos. Inherits access control from the parent user document."
    }
  }
}
